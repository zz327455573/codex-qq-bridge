# ==========================================
#  Codex QQ Bridge 环境变量配置模板
# ==========================================
# 复制此文件为 .env 并填入你的参数：
#   cp .env.example .env

# 1. QQ 开放平台机器人凭证（必填）
#    在 https://bot.q.qq.com 应用管理后台获取
APP_ID=your_app_id_here
CLIENT_SECRET=your_client_secret_here

# 2. 管理员用户 OpenID（必填）
#    桥接器只响应此用户发送的私聊消息
#    留空时会自动绑定第一个发消息的用户
MASTER_OPENID=your_master_openid_here

# 3. tmux 会话名称（可选，默认 codex）
#    Codex 将在该 tmux 会话中常驻运行
TMUX_SESSION=codex

# 4. Codex 数据目录（可选，默认 ~/.codex）
#    用于定位 Codex 的 sessions/ 目录（含 rollout-*.jsonl）
# CODEX_HOME=/root/.codex
